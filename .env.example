# Bungie API credentials — get these from https://www.bungie.net/en/Application
# Copy this file to `.env.local` and fill in the values.

# Required for all API calls (X-API-Key header)
BUNGIE_API_KEY=

# OAuth2 Authorization Code flow (used in build step #2 — logged-in mode)
BUNGIE_OAUTH_CLIENT_ID=
BUNGIE_OAUTH_CLIENT_SECRET=
BUNGIE_REDIRECT_URL=http://localhost:3000/api/auth/callback

# Secret used to encrypt session/refresh tokens (any long random string).
# Generate with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=
